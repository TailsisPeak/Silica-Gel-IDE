<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SilicaGel"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             x:Class="SilicaGel.CodeEditorView"
             x:DataType="vm:EditorTabViewModel">
    <Grid RowDefinitions="*,24">
        <ae:TextEditor Grid.Row="0"
                       Name="Editor"
                       Background="{DynamicResource BgEditor}"
                       Foreground="{DynamicResource FgPrimary}"
                       FontFamily="Cascadia Code, Consolas, Menlo, 'JetBrains Mono', monospace"
                       FontSize="14"
                       ShowLineNumbers="True"
                       WordWrap="False" />
        <Border Grid.Row="1" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource Stroke}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="14" Margin="10,0">
                <TextBlock Text="{Binding Language}" Classes="muted" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Classes="muted" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ProblemSummary}" Classes="muted" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
