 <Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- VS Code Dark+ palette -->
    <Styles.Resources>
        <Color x:Key="BgDeepColor">#1E1E1E</Color>
        <Color x:Key="BgPanelColor">#252526</Color>
        <Color x:Key="BgEditorColor">#1E1E1E</Color>
        <Color x:Key="BgSidebarColor">#252526</Color>
        <Color x:Key="BgActivityColor">#333333</Color>
        <Color x:Key="BgTitleColor">#3C3C3C</Color>
        <Color x:Key="BgHoverColor">#2A2D2E</Color>
        <Color x:Key="BgSelectedColor">#37373D</Color>
        <Color x:Key="StrokeColor">#1E1E1E</Color>
        <Color x:Key="StrokeSoftColor">#2D2D30</Color>
        <Color x:Key="FgPrimaryColor">#D4D4D4</Color>
        <Color x:Key="FgMutedColor">#8C8C8C</Color>
        <Color x:Key="FgInverseColor">#FFFFFF</Color>
        <Color x:Key="AccentColor">#0E639C</Color>
        <Color x:Key="AccentBrightColor">#1F8AD2</Color>
        <Color x:Key="AccentDimColor">#094771</Color>
        <Color x:Key="ErrorColor">#F44747</Color>
        <Color x:Key="WarnColor">#FFC107</Color>

        <SolidColorBrush x:Key="BgDeep"        Color="{StaticResource BgDeepColor}" />
        <SolidColorBrush x:Key="BgPanel"       Color="{StaticResource BgPanelColor}" />
        <SolidColorBrush x:Key="BgEditor"      Color="{StaticResource BgEditorColor}" />
        <SolidColorBrush x:Key="BgSidebar"     Color="{StaticResource BgSidebarColor}" />
        <SolidColorBrush x:Key="BgActivity"    Color="{StaticResource BgActivityColor}" />
        <SolidColorBrush x:Key="BgTitle"       Color="{StaticResource BgTitleColor}" />
        <SolidColorBrush x:Key="BgHover"       Color="{StaticResource BgHoverColor}" />
        <SolidColorBrush x:Key="BgSelected"    Color="{StaticResource BgSelectedColor}" />
        <SolidColorBrush x:Key="Stroke"        Color="{StaticResource StrokeColor}" />
        <SolidColorBrush x:Key="StrokeSoft"    Color="{StaticResource StrokeSoftColor}" />
        <SolidColorBrush x:Key="FgPrimary"     Color="{StaticResource FgPrimaryColor}" />
        <SolidColorBrush x:Key="FgMuted"       Color="{StaticResource FgMutedColor}" />
        <SolidColorBrush x:Key="FgInverse"     Color="{StaticResource FgInverseColor}" />
        <SolidColorBrush x:Key="Accent"        Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentBright"  Color="{StaticResource AccentBrightColor}" />
        <SolidColorBrush x:Key="AccentDim"     Color="{StaticResource AccentDimColor}" />
        <SolidColorBrush x:Key="ErrorBrush"    Color="{StaticResource ErrorColor}" />
        <SolidColorBrush x:Key="WarnBrush"     Color="{StaticResource WarnColor}" />
    </Styles.Resources>

    <!-- Window chrome -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource BgDeep}" />
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI, Inter, $Default" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource BgPanel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource StrokeSoft}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.title">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource FgMuted}" />
        <Setter Property="Margin" Value="14,8,10,6" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource FgMuted}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="Button.flat">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.flat:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgHover}" />
    </Style>

    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource FgInverse}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentDim}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBright}" />
    </Style>

    <!-- Activity bar buttons (the leftmost vertical strip) -->
    <Style Selector="Button.activity">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FgMuted}" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.activity:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FgPrimary}" />
    </Style>
    <Style Selector="Button.activity.active">
        <Setter Property="BorderBrush" Value="{DynamicResource FgPrimary}" />
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
    </Style>

    <Style Selector="ListBox.tree">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgHover}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgSelected}" />
    </Style>

    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Background" Value="{DynamicResource BgPanel}" />
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Background" Value="{DynamicResource BgEditor}" />
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
    </Style>

    <!-- Status bar (VS Code blue at the bottom) -->
    <Style Selector="Border.statusbar">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="MinHeight" Value="22" />
    </Style>
    <Style Selector="TextBlock.statusbar">
        <Setter Property="Foreground" Value="{DynamicResource FgInverse}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
</Styles>
