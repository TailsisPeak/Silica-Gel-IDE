<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SilicaGel"
             x:Class="SilicaGel.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <Border Background="{DynamicResource BgEditor}" Padding="0">
        <ScrollViewer>
            <StackPanel Margin="32" Spacing="20" MaxWidth="900" HorizontalAlignment="Left">
                <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Settings are written immediately to settings.json" Foreground="{DynamicResource FgMuted}" FontSize="12" />

                <Border Background="{DynamicResource BgPanel}" CornerRadius="4" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Editor" FontSize="14" FontWeight="SemiBold" />

                        <Grid ColumnDefinitions="220,*">
                            <TextBlock Grid.Column="0" Text="Font Family" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding FontFamily}" />
                        </Grid>
                        <Grid ColumnDefinitions="220,80,*">
                            <TextBlock Grid.Column="0" Text="Font Size (px)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1" Value="{Binding FontSize}" Minimum="8" Maximum="32" Increment="1" />
                            <Slider Grid.Column="2" Value="{Binding FontSize}" Minimum="8" Maximum="32" />
                        </Grid>
                        <Grid ColumnDefinitions="220,80,*">
                            <TextBlock Grid.Column="0" Text="Tab Size (spaces)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1" Value="{Binding TabSize}" Minimum="1" Maximum="8" Increment="1" />
                        </Grid>
                        <CheckBox Content="Word Wrap"   IsChecked="{Binding WordWrap}" />
                        <CheckBox Content="Line Numbers" IsChecked="{Binding LineNumbers}" />
                        <CheckBox Content="Show Minimap (planned)" IsChecked="{Binding Minimap}" />
                        <CheckBox Content="Auto Save"   IsChecked="{Binding AutoSave}" />
                        <CheckBox Content="Run script on save (Silica/Gel)" IsChecked="{Binding RunOnSave}" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource BgPanel}" CornerRadius="4" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Workbench" FontSize="14" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="220,*">
                            <TextBlock Grid.Column="0" Text="Color Theme" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource BgPanel}" CornerRadius="4" Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Extensions" FontSize="14" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="220,*">
                            <TextBlock Grid.Column="0" Text="Extensions folder" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding ExtensionsDir}" />
                        </Grid>
                        <TextBlock Foreground="{DynamicResource FgMuted}" FontSize="11">
                            Drop VS Code extensions (folders with package.json) or Silica Gel native extensions (.dll) into this folder.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource BgPanel}" CornerRadius="4" Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Storage" FontSize="14" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="220,*">
                            <TextBlock Grid.Column="0" Text="Config folder" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding ConfigDir}" Foreground="{DynamicResource FgMuted}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="flat" Command="{Binding OpenConfigCommand}" Content="Open Config Folder" />
                            <Button Classes="flat" Command="{Binding ResetCommand}"      Content="Reset to Defaults" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
